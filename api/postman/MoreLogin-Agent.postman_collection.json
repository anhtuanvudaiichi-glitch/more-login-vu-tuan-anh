  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "// Generate timestamp and nonce",
          "var timestamp = Math.floor(Date.now() / 1000).toString();",
          "var nonce = pm.variables.replaceIn('{{$guid}}');",
          "pm.variables.set('timestamp', timestamp);",
          "pm.variables.set('nonce', nonce);",
          "",
          "var apiKeySecret = pm.variables.get('apiKeySecret') || '';",
          "var method = pm.request.method.toUpperCase();",
          "var path = '/' + pm.request.url.path.join('/');",
          "var rawBody = '';",
          "if (pm.request.body && pm.request.body.mode === 'raw' && pm.request.body.raw) {",
          "  rawBody = pm.request.body.raw;",
          "}",
          "var bodyHash = CryptoJS.SHA256(rawBody).toString();",
          "var canonical = method + '\\n' + path + '\\n' + timestamp + '\\n' + nonce + '\\n' + bodyHash;",
          "var signature = CryptoJS.HmacSHA256(canonical, apiKeySecret).toString();",
          "pm.variables.set('signature', signature);"
        ]
      }
    }
